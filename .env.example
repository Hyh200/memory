# Runtime
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
PORT=3000

# MinIO / S3 compatible storage
# Local Docker: http://127.0.0.1:9000
# Production compose: http://minio:9000
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_REGION=us-east-1
MINIO_BUCKET=annual-photo-album
MINIO_ACCESS_KEY=replace-with-minio-access-key
MINIO_SECRET_KEY=replace-with-minio-secret-key

# Required by the MinIO container in docker-compose.prod.yml.
# For the MVP deployment these can match MINIO_ACCESS_KEY / MINIO_SECRET_KEY.
MINIO_ROOT_USER=replace-with-minio-access-key
MINIO_ROOT_PASSWORD=replace-with-minio-secret-key
